{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"include": ["./src/**/*"],
	"exclude": ["node_modules", "dist"]
}
