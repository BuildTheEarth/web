{
	"name": "web",
	"version": "1.1.0",
	"private": true,
	"author": {
		"name": "BuildTheEarth Development",
		"url": "https://buildtheearth.net/contact",
		"email": "development@buildtheearth.net"
	},
	"license": "MIT",
	"scripts": {
		"build": "turbo build",
		"build:api": "turbo build --filter=api...",
		"build:frontend": "turbo build --filter=frontend...",
		"clean": "turbo clean",
		"start": "turbo start",
		"dev": "turbo dev",
		"dev:frontend": "turbo dev --filter=frontend...",
		"lint": "turbo lint",
		"prettier": "turbo prettier --ui=stream",
		"generate:db": "turbo generate:db",
		"studio:db": "yarn workspace @repo/db studio:db",
		"migrate:db": "yarn workspace api migrate:db",
		"git:pull": "git pull && yarn install && yarn run generate:db",
		"ws": "yarn workspace"
	},
	"devDependencies": {
		"@repo/prettier-config": "*",
		"@repo/typescript-config": "*",
		"husky": "^9.1.5",
		"lint-staged": "^15.2.10",
		"turbo": "^2.5.0"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538",
	"prettier": "@repo/prettier-config"
}
