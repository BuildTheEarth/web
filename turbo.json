{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"CMS_URL",
		"NEXTAUTH_URL",
		"NEXT_PUBLIC_API_URL",
		"NEXT_PUBLIC_FRONTEND_URL",
		"NEXT_PUBLIC_KEYCLOAK_ID",
		"NEXT_PUBLIC_KEYCLOAK_URL",
		"NEXT_PUBLIC_MAPBOX_TOKEN",
		"NEXT_PUBLIC_SMYLER_API_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"db:generate",
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**"
			]
		},
		"clean": {
			"dependsOn": [
				"^clean"
			],
			"cache": false
		},
		"start": {
			"dependsOn": [
				"build"
			],
			"persistent": true,
			"cache": false
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"prettier": {
			"dependsOn": [
				"^prettier"
			]
		},
		"db:generate": {
			"cache": false
		},
		"db:studio": {
			"persistent": true,
			"cache": false
		}
	}
}