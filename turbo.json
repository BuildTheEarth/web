{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalPassThroughEnv": [
		"USERPROFILE",
		"HOME",
		"APPDATA",
		"INFISICAL_TOKEN"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"db:generate",
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**"
			]
		},
		"clean": {
			"dependsOn": [
				"^clean"
			],
			"cache": false
		},
		"start": {
			"dependsOn": [
				"build"
			],
			"persistent": true,
			"cache": false
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"prettier": {
			"dependsOn": [
				"^prettier"
			]
		},
		"db:generate": {
			"cache": false
		},
		"db:studio": {
			"persistent": true,
			"cache": false
		},
		"env:generate": {
			"cache": false
		},
		"env:copy": {
			"cache": false
		}
	}
}