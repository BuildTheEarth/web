{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["generate:db", "^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"clean": {
			"dependsOn": ["^clean"],
			"cache": false
		},
		"start": {
			"dependsOn": ["build"],
			"persistent": true,
			"cache": false
		},
		"dev": {
			"persistent": true,
			"dependsOn": ["migrate:db"],
			"cache": false
		},
		"migrate:db": {
			"dependsOn": ["wait"],
			"cache": false
		},
		"wait": {
			"dependsOn": ["up"],
			"cache": false
		},
		"up": {
			"cache": false
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"prettier": {
			"dependsOn": ["^prettier"]
		},
		"generate:db": {
			"cache": false
		},
		"studio:db": {
			"persistent": true,
			"cache": false
		}
	}
}
